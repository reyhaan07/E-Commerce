# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/shopsphere
PORT=5000

# Auth
JWT_SECRET=change-this-to-a-random-string

# Where the shared login app runs (used in password-reset email links)
LOGIN_APP_URL=http://localhost:5177

# SMTP (optional — leave unset and all email is logged to the console instead)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="ShopSphere <no-reply@example.com>"

# Razorpay TEST keys (optional — leave unset for a built-in mock checkout).
# Use rzp_test_... keys only; this project never handles live payments.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
